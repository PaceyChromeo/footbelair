rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if the requesting user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: check if the requesting user is an admin
    // Reads the user's profile document to check their role
    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // Helper: check if the requesting user owns the document
    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // =====================
    // USERS collection
    // =====================
    match /users/{userId} {
      // Any authenticated user can read any user profile
      // (penalties are public)
      allow read: if isAuthenticated();

      // Users can create their own profile on first sign-in
      allow create: if isOwner(userId);

      // Users can update their own profile (displayName, email, photoURL)
      // Admins can update any user profile (role changes, penalties)
      allow update: if isOwner(userId) || isAdmin();

      // Only admins can delete user profiles
      allow delete: if isAdmin();
    }

    // =====================
    // MATCHES collection
    // =====================
    match /matches/{matchId} {
      // Any authenticated user can read matches
      allow read: if isAuthenticated();

      // Only admins can create matches (createMatch, createWeekMatches)
      allow create: if isAdmin();

      // Any authenticated user can update matches
      // (join/leave updates players, waitingList, status)
      // Admin operations (cancel, complete, reopen, move players) also use update
      allow update: if isAuthenticated();

      // Only admins can delete matches (deleteWeekMatches, cleanup)
      allow delete: if isAdmin();
    }

    // =====================
    // NO-SHOW REPORTS collection
    // =====================
    match /noShowReports/{reportId} {
      // Only admins can read reports
      allow read: if isAdmin();

      // Any authenticated user can create a report
      allow create: if isAuthenticated();

      // Only admins can update reports (confirm/dismiss)
      allow update: if isAdmin();

      // Only admins can delete reports
      allow delete: if isAdmin();
    }

    // Deny access to all other collections by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
